generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ListingStatus {
  draft
  active
  rented
  archived
}

enum ListingType {
  rent
  sublet
  roommate
}

model ApartmentPost {
  id            String        @id @default(uuid()) @db.Uuid         // Primary key, uses UUIDs as type and default value
  url           String        @unique                              // Unique URL for the listing
  title         String
  description   String
  rent          Int
  currency      String        @default("ILS")                      // Currency code, defaults to Israeli Shekel
  address       String
  city          String
  neighborhood  String?
  latitude      Float?
  longitude     Float?
  bedrooms      Int
  bathrooms     Float
  sizeSqm       Int?
  floor         Int?
  totalFloors   Int?
  furnished     Boolean       @default(false)                      // Whether the apartment is furnished, defaults to false
  availableFrom DateTime?
  listingType   ListingType   @default(rent)                       // Enum: rent, sublet, or roommate; defaults to rent
  amenities     String[]                                            // Array of amenity strings (e.g., "elevator", "balcony")
  images        String[]                                            // Array of image URLs or paths
  status        ListingStatus @default(draft)                      // Enum: current status, defaults to draft
  postedById    String?       @db.Uuid                             // Foreign key to user who posted, UUID type
  createdAt     DateTime      @default(now())                      // Timestamp when created, set automatically
  updatedAt     DateTime      @updatedAt                           // Timestamp auto-updates on changes

  @@index([city])                                                  // Index for querying by city
  @@index([status])                                                // Index for querying by listing status
  @@index([postedById])                                            // Index for querying by poster
  @@map("apartment_posts")                                         // Maps this model to table "apartment_posts"
}
