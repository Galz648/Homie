# Non-secret defaults. Auth key goes in secrets.auto.tfvars (see secrets.auto.tfvars.example).
# Auth for DigitalOcean: DIGITALOCEAN_TOKEN in the environment — never put the token here.

droplet_name                = "homie-k3s"
region                      = "fra1"
size                        = "s-4vcpu-8gb"
image                       = "ubuntu-24-04-x64"
ssh_public_key_path         = "~/.ssh/id_ed25519.pub"
# k3s_version               = "v1.31.5+k3s1"
tags                        = ["k3s", "homie"]
data_volume_size_gb = 1

# Listing photo Spaces buckets (object storage — not block volumes).
# Override names if the defaults are taken; keys stay in secrets / ~/.config/homie.
spaces_images_enabled = true
# spaces_images_region = "fra1"   # default: same as region
# spaces_images_bucket_staging    = "homie-k3s-images-staging"
# spaces_images_bucket_production = "homie-k3s-images-production"
# After apply, set lane env:
#   HOMIE_IMAGE_UPLOAD_MODE=spaces
#   HOMIE_IMAGES_BUCKET=<terraform output spaces_images.staging.name>
#   HOMIE_IMAGES_BASE_URL=https://<bucket>.<region>.cdn.digitaloceanspaces.com
#   HOMIE_SPACES_ENDPOINT=https://<region>.digitaloceanspaces.com
#   HOMIE_SPACES_REGION=<region>
#   HOMIE_SPACES_KEY / HOMIE_SPACES_SECRET  (Spaces access key — never commit)

# Prefer Tailscale (secrets.auto.tfvars). Leave admin_cidrs empty so 22/6443
# are not on the public internet. Set a /32 only for emergency break-glass.
admin_cidrs = []
