# ── Local Supabase (supabase start) ──────────────────────────────────────────
# Use the SAME value for both when developing locally (no pooler).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# ── Remote Supabase (production / cloud) ─────────────────────────────────────
# DATABASE_URL  → port 6543, ?pgbouncer=true  → used by your app at runtime (lib/db.ts)
# DIRECT_URL    → port 5432, no pooler        → used by Prisma CLI (migrate, studio, pull)
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
